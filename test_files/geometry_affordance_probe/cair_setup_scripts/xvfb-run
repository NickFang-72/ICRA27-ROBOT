#!/usr/bin/env bash
set -euo pipefail

auto_display=0
server_args="-screen 0 1024x768x24"

while [ "$#" -gt 0 ]; do
  case "$1" in
    -a|--auto-servernum)
      auto_display=1
      shift
      ;;
    -s|--server-args)
      server_args="$2"
      shift 2
      ;;
    --)
      shift
      break
      ;;
    -*)
      shift
      ;;
    *)
      break
      ;;
  esac
done

if [ "$#" -eq 0 ]; then
  echo "Usage: xvfb-run [-a] command [args...]" >&2
  exit 2
fi

XVFB_BIN="${XVFB_BIN:-Xvfb}"
if ! command -v "$XVFB_BIN" >/dev/null 2>&1; then
  for candidate in \
    /data/yf23/conda_pkgs/xorg-xserver-xvfb-21.1.21-h1b28b03_0/bin/Xvfb \
    /data/yf23/instant_policy_cair/envs/xvfb/bin/Xvfb; do
    if [ -x "$candidate" ]; then
      XVFB_BIN="$candidate"
      break
    fi
  done
fi

if ! command -v "$XVFB_BIN" >/dev/null 2>&1 && [ ! -x "$XVFB_BIN" ]; then
  echo "Xvfb binary not found" >&2
  exit 127
fi

display="${XVFB_DISPLAY:-99}"
if [ "$auto_display" = 1 ]; then
  display=$(( (RANDOM % 400) + 100 ))
  while [ -e "/tmp/.X11-unix/X$display" ]; do
    display=$((display + 1))
  done
fi

"$XVFB_BIN" ":$display" $server_args >/tmp/xvfb-run-"$display".log 2>&1 &
xvfb_pid=$!
trap 'kill "$xvfb_pid" >/dev/null 2>&1 || true' EXIT INT TERM
sleep 1

DISPLAY=":$display" "$@"
